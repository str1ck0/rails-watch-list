<h1>My Movie Lists</h1>

<div>
  <% @lists.each do |list| %>
    <%= link_to list_path(list), class: "text-decoration-none" do %>
      <div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= cl_image_path list.photo.key, height: 300, width: 400, crop: :fill %>')">
        <%= list.name %>
        <%= link_to "🗑️", list_path(list), class: "text-decoration-none",
          data: {turbo_method: :delete, turbo_confirm: "Are you sure you want to delete #{list.name}?"} %>
      </div>
      <% end %>
    <br>
  <% end %>
</div>

<div>
  <p> <%= link_to "Create new list", new_list_path, class: "text-decoration-none" %></p>
</div>
